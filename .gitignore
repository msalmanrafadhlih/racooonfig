# =============================================================================
# Nix / Build Artifacts
# =============================================================================

# Nix build symlinks/results anywhere
**/result
**/result-*

**/beets

# Nix temporary/build/cache files
**/.nix-*
**/nix-output
**/nix-build*
**/*.drv
**/*.drv.chroot
**/*.drv.lock

# Generic caches/temp dirs anywhere
**/.cache/
**/cache/
**/tmp/
**/temp/
**/.tmp/
**/var/

# =============================================================================
# direnv / env files
# =============================================================================

**/.direnv/
**/.envrc
**/.env
**/.env.*
!**/.env.example

# =============================================================================
# Machine-specific / generated Nix files
# =============================================================================

# Usually machine-specific
flake.lock

# Uncomment if hardware config should not be tracked
# **/hardware-configuration.nix

# =============================================================================
# Logs / temporary editor files
# =============================================================================

**/*~
**/*.swp
**/*.swo
**/*.tmp
**/*.temp
**/*.bak
**/*.orig
**/*.rej
**/*.log
**/*.pid
**/*.seed
**/*.stackdump

# =============================================================================
# IDE / Editor files
# =============================================================================

**/.vscode/
**/.idea/
**/.fleet/
**/.zed/
**/*.iml
**/.project
**/.classpath
**/.settings/

# Vim / Neovim
**/.netrwhist
**/.nvimlog

# Emacs
**/.emacs.desktop
**/.emacs.desktop.lock

# =============================================================================
# OS junk
# =============================================================================

**/.DS_Store
**/.AppleDouble
**/.LSOverride
**/Thumbs.db
**/ehthumbs.db
**/desktop.ini

# Linux trash
**/.Trash-*
**/.directory

# =============================================================================
# Secrets / sensitive files
# =============================================================================

**/*.secret
**/*.private
**/*.key
**/*.pem
**/*.p12
**/*.crt
**/*.csr
**/*.asc
**/*.kdbx

# Service/account secrets
**/secrets/
**/private/
**/.sops.yaml
**/age.key
**/id_rsa
**/id_ed25519

# =============================================================================
# Language-specific junk
# =============================================================================

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.mypy_cache/
**/.venv/
**/venv/

# NodeJS
**/node_modules/
**/.pnpm-store/
**/.npm/
**/.yarn/
**/.next/
**/dist/
**/build/

# Rust
**/target/

# Go
# **/bin/
**/.coverprofile

# Java/Kotlin
**/.gradle/
**/out/

# =============================================================================
# Git internals accidentally nested
# =============================================================================
# Ignore nested repositories/submodules accidentally created
# **/.git
