* {
    background: #1a1110; /* #1e100f */
    background-alt: #410001; /* #410004 */
    background-window: #15100fdd; /* #15100f + dd */
    background-selected: #ea1e19df; /* #ed0928 + df */
    background-normal: #00000000; /* Tetap transparan (tidak ada di palet) */
    background-transparent: #ea1e1920; /* #ed0928 + 20 */
    background-gradient-active: linear-gradient(to left, #ff5544, transparent);
    background-gradient-selected: linear-gradient(to right, #c00008, transparent);

    foreground: #ffb4a9; /* #ffecea */
    foreground-selected: #f1dedc; /* #ffffff */
    foreground-normal: #15100f; /* #15100f */

    transparent: #1a1110c0; /* #1e100f + c0 */
    selected: #ff5544; /* #ff5451 */
    active: #c00008; /* #c0001c */
    urgent: #ff5449; /* #ff5449 */

    primary: #ffb4a9;
    primary-fixed: #ffdad5;
    primary-fixed-dim: #ffb4a9;
    on-primary: #561e18;
    on-primary-fixed: #3b0906;
    on-primary-fixed-variant: #73342c;
    primary-container: #73342c;
    on-primary-container: #ffdad5;
    secondary: #e7bdb7;
    secondary-fixed: #ffdad5;
    secondary-fixed-dim: #e7bdb7;
    on-secondary: #442926;
    on-secondary-fixed: #2c1512;
    on-secondary-fixed-variant: #5d3f3b;
    secondary-container: #5d3f3b;
    on-secondary-container: #ffdad5;
    tertiary: #dfc38c;
    tertiary-fixed: #fcdfa6;
    tertiary-fixed-dim: #dfc38c;
    on-tertiary: #3e2e04;
    on-tertiary-fixed: #251a00;
    on-tertiary-fixed-variant: #574419;
    tertiary-container: #574419;
    on-tertiary-container: #fcdfa6;
    error: #ffb4ab;
    on-error: #690005;
    error-container: #93000a;
    on-error-container: #ffdad6;
    surface: #1a1110;
    on-surface: #f1dedc;
    on-surface-variant: #d8c2be;
    outline: #a08c89;
    outline-variant: #534341;
    shadow: #000000;
    scrim: #000000;
    inverse-surface: #f1dedc;
    inverse-on-surface: #392e2c;
    inverse-primary: #904a41;
    surface-dim: #1a1110;
    surface-bright: #423735;
    surface-container-lowest: #140c0b;
    surface-container-low: #231918;
    surface-container: #271d1c;
    surface-container-high: #322826;
    surface-container-highest: #3d3231;

    font: "JetBrains Mono Nerd Font 10";
    image: url("/home/tquilla/.dotfiles/bspwm/configs/bspwm/rices/colorblocks/wallpapers/colorblocks.jpg", width);

    /* background: #1a0a0aff; */
