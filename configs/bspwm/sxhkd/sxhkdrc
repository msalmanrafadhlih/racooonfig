###########################################################
#  -------------------- BSPWM & SXKHD ------------------- #
###########################################################
# ==================================================  BSPWM
# ---------------------------------------------------------  Show Help
alt + F1
    open --KeyHelp
# ---------------------------------------------------------  Reload sxhkd
super + grave
    pkill -USR1 -x sxhkd && dunstify -r 1234 -t 1000 "sxhkd" "Reloaded ✅"
# ---------------------------------------------------------  Refresh bspwm
ctrl + super + alt + Return
	bspc wm -r
# ---------------------------------------------------------  Soft Reload
ctrl + super + alt + @space
	reload
# ---------------------------------------------------------  Rice Selector
alt + W
	open --rice
# ---------------------------------------------------------  wall Selector
alt + @space
	open --selectwallpaper 
# ---------------------------------------------------------  Powermenu
super + Escape
	open --powermenu
# ---------------------------------------------------------  Menu Apps
super + @space
	open --launcher
# ---------------------------------------------------------  ulauncher
ctrl + @space
	ulauncher
# ---------------------------------------------------------  Menu Bookmarks
super + alt + @space
	open --bookmarks
# ---------------------------------------------------------  Close Apps
super + q
	bspc node -c
###########################################################
# ------------------ Applications ----------------------- #
###########################################################
# ==============================================  MAIN APPS
# ---------------------------------------------------------  Terminal
super + Return
	open --terminal
# ---------------------------------------------------------  audio
super + a
	open --audiocontrol
# ---------------------------------------------------------  Browser
super + b
	open --browser
# ---------------------------------------------------------  Open Discord
super + d
	open --discord
# ---------------------------------------------------------  file manager
super + f
	open --filemanager
# ---------------------------------------------------------  Terminal IDE
super + n
	open --terminalIDE 
# ---------------------------------------------------------  Music
super + m
    open --music
# ---------------------------------------------------------  Picart
super + v
    open --musictagger
# ---------------------------------------------------------  Terminal pinned
super + p
	open --terminalpin 
# ---------------------------------------------------------  Spotify
super + s
	open --spotify
# ---------------------------------------------------------  Yazi
super + y
	open --yazi
# ---------------------------------------------------------  GUI Editor
super + z
	open --editor

# =============================================== UTILITIES
# ---------------------------------------------------------  Hide/Show Polibar
super + alt + p
	PolybarLogics --toggle
# ---------------------------------------------------------  Btop++
super + alt + b
    open --btop
# ---------------------------------------------------------  Clipboard Manager
super + alt + c
	open --clipboard
# ---------------------------------------------------------  Switch Default Terminal 
super + alt + t
	open --switchterminal

###########################################################
# ---------------------- Workspaces --------------------- #
###########################################################
# =================================================== 1 - 9
# ---------------------------------------------------------  Swap workspace by arrow
super + {Left,Right}
	bspc desktop -f {prev,next}
# ---------------------------------------------------------  Swap workspace by h,l
super + {h,l}
	bspc desktop -f {prev,next}
# ---------------------------------------------------------  Swap workspace by j,k
super + {k,j}
	bspc desktop -f {prev,next}
# ------f--------------------------------------------------  Swap Workspace by number
super + {1-9,0}
    bspc desktop -f '^{1-9,10}'

# =================================================== NODES
# ========================================== NAVIGATE NODES
# ---------------------------------------------------------  Move focused Node to spesific workspace
super + shift + {1-9,0}
	bspc node -d '^{1-9,10}'
# ---------------------------------------------------------  Move focused NOde to spesific worksapce by arrow
super + shift + {Left,Right}
	bspc node -d {prev,next} '--follow'
# ---------------------------------------------------------  Swap Focused Node
super + alt + {Left,Down,Up,Right}
	{ DIR=west FALLBACK=prev; , DIR=south; , DIR=north; , DIR=east FALLBACK=next; } \
	bspc node -f $DIR.!sticky.!hidden.local || bspc node -f $FALLBACK.leaf.!sticky.!hidden.local
# ---------------------------------------------------------  Swap Node
super + ctrl + {Left,Down,Up,Right}
	bspc node -s {west,south,north,east}.local
# ---------------------------------------------------------  Bring all Nodes to spesific workspace
# super + shift + a ; {1-9}
#     	bspc query -N -d {1-9} -n '.window' | xargs -I id -n 1 bspc node id -d focused
# ---------------------------------------------------------  Bring all Marked Node to focused workspace
# super + shift + m ; {1-9}
#     	bspc query -N -n '.marked' | xargs -I id -n 1 bspc node id -d focused --follow
# ---------------------------------------------------------  Increase / Deacrese Nodes
super + shift + {plus,minus}
	{ \
       bspc node -z top_right 20 -20 ; bspc node -z bottom_left -20 20; \
    ,  bspc node -z top_right -20 20 ; bspc node -z bottom_left 20 -20; \
    }
# ---------------------------------------------------------  switch nodes
super + Tab
	open --switcher

# ========================================== FLOATING NODES
# ---------------------------------------------------------  Move floating window
alt + shift + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

# ---------------------------------------------------------  Move floating window
# ctrl + shift + {plus,minus}
# 	{ \
# 	  xdotool getactivewindow windowmove --relative -- -50 -25 ; xdo resize -w +100 -h +50; \
# 	, xdotool getactivewindow windowmove --relative -- +50 +25 ; xdo resize -w -100 -h -50; \
# 	}

# ============================================== PLAY NODES
# ---------------------------------------------------------  NODE Display
super + shift + {a,d,w,s}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}
# ---------------------------------------------------------  NODE Status
super + shift + {m,n,c,p,h}
	bspc node -g {marked,locked,sticky,private,hidden}
# ---------------------------------------------------------  Toggle monocle <-> tiled
super + shift + t
	bspc desktop -l next
# ---------------------------------------------------------  Show NODE
super + shift + u
	bspc node $(bspc query -N -n .hidden.local.window | head -n1) --flag hidden=off
# ---------------------------------------------------------  NODE Transparensi
super + ctrl + minus
    picom-trans -c -3

super + ctrl + equal
    picom-trans -c +3

super + ctrl + 0
    picom-trans -c -d
# ---------------------------------------------------------  Rotate Node 90^
super + shift + Tab
	bspc node @/ --rotate 90
# ---------------------------------------------------------  CloSe/kill Nodes
super + {_,shift + }q
	bspc node -{c,k}
# ---------------------------------------------------------  Balance Nodes
super + shift + b
  bspc node @/ -B}
# ---------------------------------------------------------  Screenshot
ctrl + shift + s
  flameshot gui
# ---------------------------------------------------------  Control Direction
super + shift {Up,Down,Return}
	bspc node -p {east,south,cancel}
# ---------------------------------------------------------  Kill all Current nodes in workspace
super + ctrl + x
	bspc query -N -d | xargs -I id -n 1 bspc node id -c
# ---------------------------------------------------------  Focused the last node/desktop
alt + {Tab,period}
  bspc {node,desktop} -f last
# ---------------------------------------------------------  kill all unfocused nodes
super + shift + k ; {x,k}
    bspc query -N -n '.!focused.!marked.local.window' | xargs -I id -n 1 bspc node id {-c,-k}

# ==================================================  OTHER
# ---------------------------------------------------------  Brightness
# XF86MonBrightnessUp
alt + shift + period
    brightness --up

# XF86MonBrightnessDown
alt + shift + comma
    brightness --down

# ---------------------------------------------------------  Volume
# XF86AudioRaiseVolume
alt + shift + equal
    set-volume --inc

# XF86AudioLowerVolume
alt + shift + minus
    set-volume --dec

# XF86AudioMute
alt + shift + 0
    set-volume --toggle

# ---------------------------------------------------------- Audio
XF86AudioNext
    sh media-play --next

XF86AudioPrev
    sh media-play --previous

XF86AudioPlay
    sh media-play --toggle

XF86AudioStop
    sh media-play --stop

# ----------------------------------------------------------- Thouchpad
XF86TouchpadToggle
    ~/.local/bin/toggle_touchpad.sh
