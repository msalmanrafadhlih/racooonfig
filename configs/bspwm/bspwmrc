#!/bin/sh

bspc monitor -d 1 2 3 4 5 6

# Clean Wayland leftovers
unset WAYLAND_DISPLAY
unset WAYLAND_SOCKET
unset HYPRLAND_INSTANCE_SIGNATURE
unset HYPRLAND_CMD
unset SWAYSOCK
unset NIXOS_OZONE_WL

# X11 session
export DISPLAY=:0
export XDG_SESSION_TYPE=x11
export XDG_CURRENT_DESKTOP=bspwm
export XDG_SESSION_DESKTOP=bspwm
export DESKTOP_SESSION=bspwm

# Toolkit backend
export GDK_BACKEND=x11
export QT_QPA_PLATFORM=xcb
export SDL_VIDEODRIVER=x11
export CLUTTER_BACKEND=x11

# Electron
export OZONE_PLATFORM=x11
export ELECTRON_OZONE_PLATFORM_HINT=x11

# Java
export _JAVA_AWT_WM_NONREPARENTING=1

# PATH
export PATH="$HOME/.config/bspwm/bin:$HOME/.local/bin:$PATH"

# Sync dbus env
dbus-update-activation-environment --systemd \
    DISPLAY \
    XDG_CURRENT_DESKTOP \
    XDG_SESSION_TYPE \
    DESKTOP_SESSION

run() {
    if ! pidof -q "$1"; then
        "$@" &
    fi
}

bspc config external_rules_command ~/.config/bspwm/bin/ExternalRules

# Border
bspc config left_padding 50
bspc config border_width 3
bspc config window_gap 5
bspc config focus_follows_pointer true
bspc config pointer_follows_focus false
bspc config pointer_follows_monitor true
bspc config pointer_motion_interval 7
bspc config pointer_modifier mod4
bspc config pointer_action1 move
bspc config pointer_action2 resize_side
bspc config pointer_action3 resize_corner

# Behavior
bspc config split_ratio 0.52
bspc config borderless_monocle false
bspc config gapless_monocle true
bspc config single_monocle true

# tiled mode
bspc config automatic_scheme longest_side # options: alternate, longest_side, spiral
bspc config initial_polarity second_child # to set new node in left or right
bspc config removal_adjustment true # atur ulang layout, saat window (tiled mode) ditutup

Colors &
~/.fehbg &
LaunchBar &
Dock &

pgrep -x clipmenud > /dev/null || clipmenud &
pgrep -x picom > /dev/null || picom &
pgrep -x sxhkd > /dev/null || sxhkd &
pgrep -x dunst > /dev/null || dunst &
