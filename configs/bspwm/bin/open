#!/bin/sh

DIR="$HOME/.config/eww"

case "$1" in
	--launcher)
		launcher
		;;
	--rice)
		SelectRice
		;;
	--selectwallpaper)
		WallSelect
		;;
	--powermenu)
		PowerMenu
		;;
	--bookmarks)
		Bookmarks
		;;
	--clipboard)
		clipboard
		;;
	--switchterminal)
		Term --selecterm
		;;
	--terminal)
		Term --terminal
		;;
	--terminalpin)
		Term --pinned
		;;
	--btop)
		Term --btop
		;;
	--yazi)
		Term --yazi
		;;
	--music)
		Term --music
		;;
	--terminalIDE)
		Term --"$EDITOR"
		;;
		# Apps
	--gemini)
		GeminiAI
		;;
	--cloude)
		CloudeAI
		;;
	--chatgpt)
		ChatGPT
		;;
	--filemanager)
		thunar
		;;
	--browser)
		kdocker -f -q "$BROWSER"
		;;
	--editor)
		zeditor
		;;
	--ulauncher)
		ulauncher
		;;
	--discord)
		vesktop
		;;
	--spotify)
		flatpak run com.spotify.Client
		;;
	--musictagger)
		picard
		;;
	--telegram)
		telegram-desktop
		;;
	--whatsapp)
		firefox -new-tab https://web.whatsapp.com/
		;;
	--audiocontrol)
		pavucontrol
		;;
		# Eww Widgets
	--KeyHelp)
		eww -c "$DIR" open --toggle csheet
		;;
	--usercard)
		eww -c "$DIR" open --toggle launchermenu
		;;
	--player)
		eww -c "$DIR" open --toggle music
		;;
	*)
		echo "Invalid Option"
		;;
esac
