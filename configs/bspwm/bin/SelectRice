#!/usr/bin/env bash
set -euo pipefail

DIR="$HOME/.config/$XDG_CURRENT_DESKTOP"
[ -f "$DIR/.rice" ] && current_rice=$(< "$DIR/.rice") || current_rice=""

# Ambil list folder, simpan ke array
mapfile -t rices < <(find "$DIR/rices/" -mindepth 1 -maxdepth 1 -type d -printf "%f\n" | sort)

# Cari index untuk row default di rofi
selected_index=-1
for i in "${!rices[@]}"; do
   if [[ "${rices[$i]}" == "$current_rice" ]]; then
       selected_index=$i
       break
   fi
done

# Generate list untuk rofi dengan ikon
selected=$(
    for rice in "${rices[@]}"; do
        printf "%s\0icon\x1f%s/rices/%s/preview.webp\n" "$rice" "$DIR" "$rice"
    done | rofi -dmenu -show-icons -p "RiceSelector" \
        -theme "$HOME/.config/rofi/themes/RiceSelector.rasi" \
        -selected-row "$selected_index"
)

# Eksekusi jika ada pilihan baru
if [[ -n "$selected" && "$selected" != "$current_rice" ]]; then
    echo "$selected" > "$DIR/.rice"
    "$DIR/bin/GenerateTheme" &
fi
