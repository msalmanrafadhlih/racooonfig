#!/usr/bin/env bash

wid=$1
class=$2
instance=$3
sleep 0.05
title=$(xprop -id "$wid" _NET_WM_NAME WM_NAME 2> /dev/null | grep -oP '"\K[^"]+(?=")' | head -1)

# ==========================================
# FUNGSI PERHITUNGAN POSISI DINAMIS
# ==========================================
# Cara pakai: calc_rect "posisi" "lebar" "tinggi" "offset_X" "offset_Y"
# - Lebar/Tinggi: Isi 0 jika ingin menggunakan ukuran asli (auto-detect).
# - offset_X    : Nilai positif geser ke KANAN, negatif ke KIRI.
# - offset_Y    : Nilai positif geser ke ATAS, negatif ke BAWAH.
calc_rect() {
    local pos=$1
    local w=$2
    local h=$3
    local off_x=${4:-0}
    local off_y=${5:-0}

    # Deteksi otomatis ukuran monitor yang sedang aktif
    local mon_w
    mon_w=$(bspc query -T -m | grep -oP '"width":\K[0-9]+' | head -n 1)

    local mon_h
    mon_h=$(bspc query -T -m | grep -oP '"height":\K[0-9]+' | head -n 1)

    mon_w=${mon_w:-1920}
    mon_h=${mon_h:-1080}

    # Jika ukuran diset 0, ambil dari geometri request aplikasi
    if [[ -z "$w" || "$w" == 0 ]]; then
        w=$(xwininfo -id "$wid" 2> /dev/null | awk '/Width:/ {print $2}')
        w=${w:-800}
    fi
    if [[ -z "$h" || "$h" == 0 ]]; then
        h=$(xwininfo -id "$wid" 2> /dev/null | awk '/Height:/ {print $2}')
        h=${h:-600}
    fi

    local x=0
    local y=0

    # Kalkulasi posisi dasar
    case "$pos" in
        center)
            x=$(((mon_w - w) / 2))
            y=$(((mon_h - h) / 2))
            ;;
        left)
            x=0
            y=$(((mon_h - h) / 2))
            ;;
        right)
            x=$((mon_w - w))
            y=$(((mon_h - h) / 2))
            ;;
        top)
            x=$(((mon_w - w) / 2))
            y=0
            ;;
        bottom)
            x=$(((mon_w - w) / 2))
            y=$((mon_h - h))
            ;;
        top-left)
            x=0
            y=0
            ;;
        top-right)
            x=$((mon_w - w))
            y=0
            ;;
        bottom-left)
            x=0
            y=$((mon_h - h))
            ;;
        bottom-right)
            x=$((mon_w - w))
            y=$((mon_h - h))
            ;;
    esac

    # Terapkan fixing positioning (offset)
    x=$((x + off_x))
    y=$((y - off_y))

    echo "${w}x${h}+${x}+${y}"
}

# --- DEFINISI GEOMETRI DINAMIS ---
# Menyesuaikan logika lamamu ke sistem dinamis yang baru
MAIN=$(calc_rect "center" 1421 994 0 5)
TALL=$(calc_rect "right" 470 987 -10 5) # Agak ke kiri 15px dari batas kanan
CHAT_AI=$(calc_rect "bottom-right" 470 659 -10 53)
TERMINAL_PINNED=$(calc_rect "top-right" 470 325 -10 -35)
TERMINAL_DEFAULT=$(calc_rect "bottom-left" 750 655 50 53) 
RMPC=$(calc_rect "top-left" 750 327 50 -35)
THUNAR=$(calc_rect "right" 1102 989 -10 5)
EVINCE=$(calc_rect "left" 746 996 50 5)
CENTER_PINNED=$(calc_rect "top" 550 350 0 -35)
RECT_YAZI=$(calc_rect "center" 900 442)
FLATPAK=$(calc_rect "center" 1796 968)

# --- LOGIC RULES ---
case "$class" in
    "Code" | "code-oss")
        case "$title" in
            *"Chat"* | *"Visual"*)
                echo "state=floating rectangle=$TALL
            "
                ;;
            *".Chromium")
                echo "state=floating rectangle=$MAIN"
                ;;
        esac
        ;;
    "Plank" | "Vivaldi-stable")
        case "$title" in
            *"Notification"* | *"Calendar"* | *"Settings"*)
                echo "state=floating"
                ;;
        esac
        ;;

    "Chromium-browser")
        case "$title" in
            *" • "*)
                echo "state=floating"
                ;;
        esac
        ;;

    "ChatAi" | "GeminiAi" | "ClaudeAi" | "youtube" | "reddit")
        case "$instance" in
            *"youtube.com"* | *"reddit.com"*)
                echo "desktop=^4 state=floating sticky=off rectangle=$MAIN"
                ;;
            *"gemini.google.com"* | *"claude.ai"* | *"chat.openai.com"*)
                echo "state=floating rectangle=$CHAT_AI"
                ;;
            *)
                case "$title" in
                    *"ChatGPT"* | *"Claude"*)
                        echo "state=floating rectangle=$CHAT_AI"
                        ;;
                    *"YouTube"* | *"reddit"*)
                        echo "desktop=^3 state=floating sticky=off rectangle=$MAIN"
                        ;;
                esac
                ;;
        esac
        ;;

    *)
        if [[ "$title" == *"rmpc"* ]]; then
            echo "state=floating rectangle=$RMPC"
            exit 0
        fi
        ;;
esac

# Rules murni berdasarkan Class
case "$class" in
    "TerminalDefault" | "kitty" | "Alacritty" | "St" )
        echo "state=floating sticky=off rectangle=$TERMINAL_DEFAULT"
        ;;
    "TerminalPinned")
        echo "state=floating sticky=on rectangle=$TERMINAL_PINNED"
        ;;
    "floating_rmpc")
        echo "state=floating rectangle=$RMPC"
        ;;
    "TerminalIDE")
        echo "desktop=^3 follow=on state=pseudo_tiled rectangle=$FLATPAK"
        ;;
    "YaziTerm")
        echo "state=floating rectangle=$(calc_rect "center" 0 0)"
        ;;
    "qView")
        echo "state=floating rectangle=$(calc_rect "center" 0 0) sticky=off"
        ;;
    "Spotify")
        echo "desktop=^4 state=pseudo_tiled rectangle=$FLATPAK"
        ;;
    "vesktop")
        echo "desktop=^5 state=pseudo_tiled rectangle=$FLATPAK"
        ;;
    "Vivaldi-stable")
        echo "desktop=^2 state=pseudo_tiled rectangle=$FLATPAK"
        ;;
    "emulator")
        echo "state=floating center=on"
        ;;
    "mpv")
        echo "state=floating center=on"
        ;;
    "Nwg-look")
        echo "state=floating center=on"
        ;;
    "Evince")
        echo "state=floating rectangle=$EVINCE"
        ;;
    "XTerm")
        echo "state=floating sticky=off rectangle=$TERMINAL_DEFAULT"
        ;;
    "Dconf-editor")
        echo "state=floating"
        ;;
    "Audacity" | "Org.gnome.gThumb")
        echo "state=floating center=on"
        ;;
    *)
        echo "state=floating"
        ;;
esac

case "$title" in
    *"yazi"*)
        echo "state=floating rectangle=$RECT_YAZI"
        ;;
    *"Thunar"*)
        echo "desktop=^1 follow=on state=floating rectangle=$THUNAR"
        ;;
    "Bluetooth Devices")
        echo "state=floating sticky=on rectangle=$CENTER_PINNED"
        ;;
    *"Settings"* | *"Preferences"* | *"Configuration"*)
        echo "state=floating center=on follow=on"
        ;;
esac
