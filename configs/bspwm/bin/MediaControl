#!/usr/bin/env bash

# Here the cover image will be saved.
Cover=/tmp/cover.png
# if cover not found in metadata use this instead
bkpCover=~/.config/eww/music-player/assets/cover.jpg
# mpd music directory for mpd clients.
mpddir=~/Music
LAST_SONG_FILE="/tmp/last_song.txt"

# 1. Deteksi Player yang aktif
PLAYER=""
# Cek playerctl (Spotify, Browser, dll)
if playerctl status 2>/dev/null | grep -qE "Playing|Paused"; then
    PLAYER=$(playerctl -l | head -n 1) # Ambil nama player (misal: spotify)
# Jika tidak ada, cek MPD
elif mpc status 2>/dev/null | grep -qE "\[playing\]|\[paused\]"; then
    PLAYER="MPD"
fi

# 2. Rutekan perintah berdasarkan player aktif
case "$1" in
    --player)
        echo "$PLAYER"
        ;;
    --title)
        if [ "$PLAYER" == "MPD" ]; then
            mpc current -f "%title%"
        else
            playerctl -p "$PLAYER" metadata title
        fi
        ;;
    --artist)
        if [ "$PLAYER" == "MPD" ]; then
            mpc current -f "%artist%"
        else
            playerctl -p "$PLAYER" metadata artist
        fi
        ;;
    --status)
        if [ "$PLAYER" == "MPD" ]; then
            # Format output mpc agar sama dengan playerctl (Playing/Paused)
            mpc status | grep -oP '\[\K[^\]]+' | head -n 1 | sed 's/.*/\u&/'
        else
            playerctl -p "$PLAYER" status
        fi
        ;;
    --toggle)
        if [ "$PLAYER" == "MPD" ]; then mpc toggle; else playerctl -p "$PLAYER" play-pause; fi
        ;;
    --next)
        if [ "$PLAYER" == "MPD" ]; then mpc next; else playerctl -p "$PLAYER" next; fi
        ;;
    --previous)
        if [ "$PLAYER" == "MPD" ]; then mpc prev; else playerctl -p "$PLAYER" previous; fi
        ;;
    --cover)
        # Logika Cover Art
        if [ "$PLAYER" == "MPD" ]; then
            current_song=$(mpc current -f "%title%-%artist%")
    				last_song=""
    				[ -f "$LAST_SONG_FILE" ] && last_song=$(cat "$LAST_SONG_FILE")

    				if [ "$current_song" != "$last_song" ] || [ ! -f "$Cover" ]; then
    					ffmpeg -i "$mpddir/$(mpc current -f %file%)" "$Cover" -y > /dev/null 2>&1 || cp "$bkpCover" "$Cover"
    					echo "$current_song" > "$LAST_SONG_FILE"
    				fi

    				echo "$Cover"
        else
            current_song="$(playerctl --player="$Control" metadata --format '{{title}}-{{artist}}')"
    				last_song=""
    				[ -f "$LAST_SONG_FILE" ] && last_song=$(cat "$LAST_SONG_FILE")

    				if [ "$current_song" != "$last_song" ] || [ ! -f "$Cover" ]; then
    					albumart="$(playerctl --player="$Control" metadata mpris:artUrl | sed -e 's/open.spotify.com/i.scdn.co/g')"
    					art_url=$(playerctl --player="$Control" metadata mpris:artUrl)
                        if [ -n "$art_url" ]; then
                            albumart=$(echo "$art_url" | sed -e 's/open.spotify.com/i.scdn.co/g')
                            curl -s "$albumart" --output "$Cover"
                        else
                            cp "$bkpCover" "$Cover"
                        fi
    				echo "$current_song" > "$LAST_SONG_FILE"
    				fi

    				echo "$Cover"
        fi
        ;;
    --position)
        if [ "$PLAYER" == "MPD" ]; then
            position=$(mpc status %currenttime%)
            echo "${position:-0:00}"
        else
            position=$(playerctl --player="$Control" position --format "{{ duration(position) }}")
            echo "${position:-0:00}"
        fi
        ;;
    --positions)
        if [ "$PLAYER" == "MPD" ]; then
            positions=$(mpc status %currenttime% | awk -F: '{print ($1 * 60) + $2}')
            echo "${positions:-0}"
        else
            positions=$(playerctl --player="$Control" position | sed 's/..\{6\}$//')
            echo "${positions:-0}"
        fi
        ;;
    --length)
        if [ "$PLAYER" == "MPD" ]; then
            length=$(mpc status %totaltime%)
            echo "${length:-0:00}"
        else
            length=$(playerctl --player="$Control" metadata --format "{{ duration(mpris:length) }}")
            echo "${length:-0:00}"
        fi
        ;;
    --lengths)
        if [ "$PLAYER" == "MPD" ]; then
            lengths=$(mpc status %totaltime% | awk -F: '{print ($1 * 60) + $2}')
            echo "${lengths:-0}"
        else
            lengths=$(playerctl --player="$Control" metadata mpris:length | sed 's/.\{6\}$//')
            echo "${lengths:-0}"
        fi
        ;;
    --shuffle)
        if [ "$PLAYER" == "MPD" ]; then
            shuffle=$(mpc status | sed -n '3s/.*random: \([^ ]*\).*/\1/p' | sed 's/.*/\u&/')
            echo "${shuffle:-Off}"
        else
            shuffle=$(playerctl --player="$Control" shuffle)
            echo "${shuffle:-Off}"
        fi
        ;;
    --loop)
        if [ "$PLAYER" == "MPD" ]; then
            loop=$(mpc status | sed -n '3s/.*repeat: \([^ ]*\).*/\1/p' | sed 's/.*/\u&/')
            echo "${loop:-Off}"
        else
            loop=$(playerctl --player="$Control" loop)
            echo "${loop:-None}"
        fi
        ;;
esac 2>/dev/null
