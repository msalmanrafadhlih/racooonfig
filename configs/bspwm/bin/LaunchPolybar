#!/usr/bin/env bash

dir="$HOME/.config/polybar"
themes=(`ls --hide="launch.sh" $dir`)

cache_it() {
	echo "$style" > "$dir/.mode"
}

launch_bar() {
	# Terminate already running bar instances
	pkill polybar

	# Wait until the processes have been shut down
	while pgrep -u $UID -x polybar >/dev/null; do sleep 1; done

	# Launch the bar
	"$dir/$style/launch.sh" &	
}

if [[ "$1" == "--material" ]]; then
	style="material"
	cache_it
	launch_bar

elif [[ "$1" == "--shades" ]]; then
	style="shades"
	cache_it
	launch_bar

elif [[ "$1" == "--hack" ]]; then
	style="hack"
	cache_it
	launch_bar

elif [[ "$1" == "--docky" ]]; then
	style="docky"
	cache_it
	launch_bar

elif [[ "$1" == "--cuts" ]]; then
	style="cuts"
	cache_it
	launch_bar

elif [[ "$1" == "--shapes" ]]; then
	style="shapes"
	cache_it
	launch_bar

elif [[ "$1" == "--grayblocks" ]]; then
	style="grayblocks"
	cache_it
	launch_bar

elif [[ "$1" == "--blocks" ]]; then
	style="blocks"
	cache_it
	launch_bar

elif [[ "$1" == "--colorblocks" ]]; then
	style="colorblocks"
	cache_it
	launch_bar

elif [[ "$1" == "--forest" ]]; then
	style="forest"
	cache_it
	launch_bar

elif [[ "$1" == "--pwidgets" ]]; then
	style="pwidgets"
	cache_it
	launch_bar

elif [[ "$1" == "--panels" ]]; then
	style="panels"
	cache_it
	launch_bar

else
	cat <<- EOF
	Usage : launch.sh --theme
		
	Available Themes :
	--blocks    --colorblocks    --cuts      --docky
	--forest    --grayblocks     --hack      --material
	--panels    --pwidgets       --shades    --shapes
	EOF
fi
