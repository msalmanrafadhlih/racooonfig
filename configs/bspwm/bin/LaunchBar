#!/usr/bin/env bash

set -euo pipefail

TMP_CONFIG="/tmp/polybar_${UID}.ini"
TMP_WIDGETS="/tmp/pwidgets_${UID}.ini"
DIR_CONFIG="$HOME/.config/$XDG_CURRENT_DESKTOP"
RICE="$DIR_CONFIG/.rice"
TMP="$HOME/.cache/.done"

[ -f "$RICE" ] && read -r BAR < "$RICE" || BAR=panels
[ -f "$HOME/.config/polybar/pwidgets/.var" ] && . "$HOME/.config/polybar/pwidgets/.var" || widgets=""

[ -f "$DIR_CONFIG/rices/$BAR/.var" ] && . "$DIR_CONFIG/rices/$BAR/.var" 

# 1. Regenerasi config jika hilang
if [[ ! -f "$TMP_CONFIG" ]]; then
    GenerateWidget --"$widgets"

    if [[ ! -f "$TMP" ]]; then
        GenerateTheme
        touch "$TMP"
    elif pgrep -f eww >/dev/null; then
        pgrep -af "eww.*" \
        | awk '{for(i=1;i<=NF;i++) if($i=="-c") print $(i+1)}' \
        | sort -u \
        | while read -r cfg; do
            [ -d "$cfg" ] || continue

            eww -c "$cfg" ping >/dev/null 2>&1 || eww -c "$cfg" daemon
            eww -c "$cfg" reload
        done
    else
        "$DIR_CONFIG/rices/$BAR/launch.sh" &
    fi
    exit 0
elif pgrep -x polybar >/dev/null; then
    polybar-msg cmd restart >/dev/null
    exit 0
else
    # 2. Deteksi Hardware
    adp=$(find /sys/class/power_supply -maxdepth 1 -type l -name "A*" -exec basename {} \; | head -n1 || echo "AC")
    bat=$(find /sys/class/power_supply -maxdepth 1 -type l -name "BAT*" -exec basename {} \; | head -n1 || echo "BAT0")
    card=$(find /sys/class/backlight -maxdepth 1 -type l -exec basename {} \; | head -n1 || echo "")
    net=$(ip -o -4 route show to default | awk '{print $5}' | head -n1 || echo "eth0")

    # Deteksi Suhu (Variabel diperbaiki jadi 'temp')
    temp=$(for i in /sys/class/hwmon/hwmon*/temp*_input; do
        if [ "$(<$(dirname "$i")/name)" = "coretemp" ] && [ "$(<${i%_*}_label)" = "Package id 0" ]; then
            echo "$i"
            exit 0
        fi
    done || echo "")

    # 3. Ambil List Bar dan Widget
    bars=$(grep '^\[bar/' "$TMP_CONFIG" 2> /dev/null | sed 's/^\[bar\///; s/\]$//' || echo "")
    widgets=$(grep '^\[bar/' "$TMP_WIDGETS" 2> /dev/null | sed 's/^\[bar\///; s/\]$//' || echo "")

    # 4. Bersihkan proses lama
    pkill polybar || true
    while pgrep -u "$UID" -f polybar > /dev/null; do sleep 0.3; done

    # Fungsi Launch (Variabel 'mon' dipassing sebagai argumen agar lebih bersih)
    launch_polybar() {
        local target_bar=$1
        local config_file=$2
        local monitor_name=$3

        MONITOR="$monitor_name" \
        ADAPTER="$adp" \
        BATTERY="$bat" \
        BACKLIGHT="$card" \
        TEMPERATURE="$temp" \
        NETWORK="$net" \
        polybar -q "$target_bar" -c "$config_file" &
    }

    # Logika Case untuk menentukan apa yang diluncurkan
    case "${1:-}" in
        --polybar)
            TARGET_B=$bars
            TARGET_W=""
            ;;
        --widgets)
            TARGET_B=""
            TARGET_W=$widgets
            ;;
        *)
            TARGET_B=$bars
            TARGET_W=$widgets
            ;;
    esac

    # 7. Eksekusi Launching (Satu loop untuk semua kondisi)
    while read -r mon; do
        # Jalankan Panels
        for b in $TARGET_B; do
            launch_polybar "$b" "$TMP_CONFIG" "$mon"
        done

        # Jalankan Widgets
        for w in $TARGET_W; do
            launch_polybar "$w" "$TMP_WIDGETS" "$mon"
        done
    done < <(polybar --list-monitors | cut -d: -f1)
fi

