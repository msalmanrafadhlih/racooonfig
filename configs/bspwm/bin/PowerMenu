#!/usr/bin/env bash

## Author : Aditya Shakya (adi1090x)
## Github : @adi1090x

# Current Theme
dir="$HOME/.config/rofi/themes"
theme='powermenu'

# CMDs
uptime="$(
    secs=$(cut -d. -f1 /proc/uptime)

    days=$((secs / 86400))
    hours=$(((secs % 86400) / 3600))
    mins=$(((secs % 3600) / 60))
    seconds=$((secs % 60))

    icon="ó°Ą”"
    printf "%s  %02dd %02dh %02dm %02ds" \
        "$icon" "$days" "$hours" "$mins" "$seconds"
)"

host=$(hostname)

# Options
shutdown='î§€'
reboot='î§„'
lock='î¦Ź'
suspend='î¦Ł'
logout='î¦‘'
yes='î¤¬'
no='î¨’'

# Rofi CMD
rofi_cmd() {
    rofi -dmenu \
        -p "See you, ${USER}" \
        -mesg "Uptime: $uptime" \
        -theme "${dir}/${theme}.rasi"
}

# Confirmation CMD
confirm_cmd() {
    rofi -dmenu \
        -p 'Confirmation' \
        -mesg 'Are you Sure?' \
        -theme "${dir}/powermenu-confirm.rasi"
}

# Ask for confirmation
confirm_exit() {
    echo -e "$yes\n$no" | confirm_cmd
}

# Pass variables to rofi dmenu
run_rofi() {
    echo -e "$lock\n$suspend\n$logout\n$reboot\n$shutdown" | rofi_cmd
}

# Execute Command
run_cmd() {
    selected="$(confirm_exit)"

    if [[ "$selected" == "$yes" ]]; then

        if [[ $1 == '--shutdown' ]]; then
            systemctl poweroff

        elif [[ $1 == '--reboot' ]]; then
            systemctl reboot

        elif [[ $1 == '--lock' ]]; then

            if [[ "$XDG_CURRENT_DESKTOP" == 'bspwm' ]]; then
                Screenlock > /dev/null 2>&1 &

            elif [[ "$XDG_CURRENT_DESKTOP" == 'Hyprland' ]]; then
                ~/.config/hypr/scripts/lock.sh

            else
                exit 1
            fi

        elif [[ $1 == '--suspend' ]]; then

            if [[ "$XDG_CURRENT_DESKTOP" == 'bspwm' ]]; then
                Screenlock > /dev/null 2>&1 &

            elif [[ "$XDG_CURRENT_DESKTOP" == 'Hyprland' ]]; then
                ~/.config/hypr/scripts/lock.sh

            else
                exit 1
            fi

            sleep 2
            mpc -q pause
            amixer set Master mute
            systemctl suspend

        elif [[ $1 == '--logout' ]]; then

            if [[ "$XDG_CURRENT_DESKTOP" == 'bspwm' ]]; then
                bspc quit

            elif [[ "$XDG_CURRENT_DESKTOP" == 'Hyprland' ]]; then
                hyprctl dispatch exit

            else
                exit 1
            fi
        fi
    else
        exit 0
    fi
}

# Actions
chosen="$(run_rofi)"

case ${chosen} in
    $shutdown)
        run_cmd --shutdown
        ;;
    $reboot)
        run_cmd --reboot
        ;;
    $lock)
        run_cmd --lock
        ;;
    $suspend)
        run_cmd --suspend
        ;;
    $logout)
        run_cmd --logout
        ;;
esac
