#!/bin/sh

# Membaca Current Rice
read -r RICE < "$HOME/.config/bspwm/.rice"

# 1. Menentukan tema dengan 'case' (lebih efisien daripada banyak 'if')
case "$RICE" in
  black)
    THEME="Vimix-black-dark"
    CURSOR="Kiana"
    ;;
  blue)
    THEME="Vimix-doder-dark"
    CURSOR="Erika-Furudo"
    ;;
  green)
    THEME="Vimix-jade-dark"
    CURSOR="Crelly-Cursor-Pack"
    ;;
  grey)
    THEME="Vimix-white-dark"
    CURSOR="Ellen-Joe"
    ;;
  red)
    THEME="Vimix-ruby-dark"
    CURSOR="Kafka"
    ;;
  *)
    THEME="Vimix-dark"
    CURSOR="Ju-Fufu"
    ;;
esac

# Menerapkan tema GTK
set-gtk-theme "dynamic" "$THEME" "$CURSOR"

# 2. Mengambil 1 file .jpg secara acak dari folder menggunakan 'shuf'
RANDOM_WALLPAPER=$(find "$HOME/Pictures/Wallpaper/$RICE" -type f | grep -iE '\.(jpg|jpeg|png|webp|bmp|gif|heic|avif|tiff)$' | shuf -n 1)

# 3. Load theme configuration dengan wallpaper acak
matugen json "$HOME/.config/bspwm/rices/$RICE/pallete.json" image "$RANDOM_WALLPAPER"
