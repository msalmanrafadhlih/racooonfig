#!/usr/bin/env bash
set -euo pipefail

# Argument handling yang lebih clean
action="${1:-"--apply"}"
theme_name="${2:-""}"

DIR="$HOME/.config/$XDG_CURRENT_DESKTOP"
read -r RICE < "$DIR/.rice"

usage() {
	cat <<- EOF
	to preview available modules

	Usage : GenerateTheme --preview [theme]		

	Available Themes :
	--blocks    --colorblocks    --cuts      --docky
	--forest    --grayblocks     --hack      --material
	--panels    --shades         --shapes
	EOF
	exit 1
}

set_theme() {
    # Cari wallpaper secara efisien
    RANDOM_WALLPAPER=$(find "$DIR/rices/$RICE/wallpapers" -type f -iregex '.*\.\(jpg\|jpeg\|png\|webp\|bmp\|gif\)' | shuf -n 1)

    if [[ -z "$RANDOM_WALLPAPER" ]]; then
        dunstify -u critical -a "Theme Manager" "Error" "Wallpaper tidak ditemukan!"
        exit 1
    fi

    # Mapping Tema & Cursor
    case "$RICE" in
        black) THEME="Vimix-black-dark"; CURSOR="Kiana" ;;
        blue)  THEME="Vimix-doder-dark"; CURSOR="Erika-Furudo" ;;
        green) THEME="Vimix-jade-dark";  CURSOR="Crelly-Cursor-Pack" ;;
        grey)  THEME="Vimix-white-dark"; CURSOR="Ellen-Joe" ;;
        red)   THEME="Vimix-ruby-dark";  CURSOR="Kafka" ;;
        *)     THEME="Vimix-white-dark"; CURSOR="Bibata-Modern-Ice" ;;
    esac

    # Apply GTK & Kitty
    set-gtk-theme "dynamic" "$THEME" "$CURSOR"
    kitten @ --to unix:/tmp/kitty set-colors --all "$HOME/.cache/wal/colors-kitty.conf" || true

    "$DIR/rices/$RICE/launch.sh" &

    # Terapkan Matugen
    if ERROR_MSG=$(matugen image "$RANDOM_WALLPAPER" --source-color-index 0 --import-json-string "{ \"cursor\": \"$CURSOR\", \"gtktheme\": \"$THEME\" }" 2>&1); then
        dunstify -u normal -a "Theme Manager" "Theme Applied!" "Rice: $RICE\nWallpaper: $(basename "$RANDOM_WALLPAPER")"
    else
        dunstify -u critical -a "Theme Manager" "Failed!" "$ERROR_MSG"
        exit 1
    fi
}

preview_theme() {
    local style="$1"
    if [[ -z "$style" || ! -d "$DIR/rices/$style" ]]; then
        usage
    fi

    pkill polybar || true
    while pgrep -x polybar >/dev/null; do sleep 0.2; done

    echo "Previewing: $style"
    "$DIR/rices/$style/preview.sh" &
}

# Logic switch
if [[ "$action" == "--preview" ]]; then
    preview_theme "$theme_name"
else
    set_theme
fi
