#!/usr/bin/env bash
set -euo pipefail

# Argument handling yang lebih clean
action="${1:-"--apply"}"
theme_name="${2:-""}"

DIR="$HOME/.config/$XDG_CURRENT_DESKTOP"
TMP_CONFIG="/tmp/polybar_${UID}".ini
read -r RICE < "$DIR/.rice"

usage() {
	cat <<- EOF

	to preview available Themes

	Available Themes :
	Usage : GenerateTheme --preview [theme]		
	--blocks    --colorblocks    --cuts      --docky
	--forest    --grayblocks     --hack      --material
	--panels    --shades         --shapes
	EOF
	exit 1
}

# kill polybar or eww
if pgrep -f "$TMP_CONFIG" >/dev/null; then
    pkill -9 -f "$TMP_CONFIG" || true
    rm -f "$TMP_CONFIG"
fi

if pgrep -u ${UID} -f eww >/dev/null; then
    eww kill 2>/dev/null || pkill eww || true
fi

set_theme() {
    # Cari wallpaper secara efisien
    # RANDOM_WALLPAPER=$(find "$DIR/rices/$RICE/wallpapers" -type f -iregex '.*\.\(jpg\|jpeg\|png\|webp\|bmp\|gif\)' | shuf -n 1)

    if RANDOM_WALLPAPER=$(find "$DIR/rices/$RICE/wallpapers/default"* -type f -iregex '.*\.\(jpg\|jpeg\|png\|webp\|bmp\|gif\)' | shuf -n 1 2>&1); then
        echo "get wallpaper..."
    else
        dunstify -r 999 -u critical -a "Theme Manager" "Error" "Wallpaper tidak ditemukan!"
        exit 1
    fi

    # Mapping Tema & Cursor
    case "$RICE" in
        colorblocks) THEME="Vimix-ruby-dark";  CURSOR="Kafka"; MODE="dark" ;;
        cuts) THEME="Vimix-ruby-dark";  CURSOR="Kafka"; MODE="dark" ;;
        docky) THEME="Vimix-white"; CURSOR="Kiana"; MODE="light" ;;
        blocks)  THEME="Vimix-doder-dark"; CURSOR="Erika-Furudo"; MODE="dark" ;;
        forest)  THEME="Vimix-jade-dark"; CURSOR="Ellen-Joe"; MODE="dark" ;;
        grayblocks) THEME="Vimix-white-dark";  CURSOR="Bibata-Modern-Ice"; MODE="light" ;;
        gruvboks) THEME="Vimix-black-dark";  CURSOR="Ellen-Joe"; MODE="dark" ;;
        hack)  THEME="Vimix"; CURSOR="Ju-Fufu"; MODE="light" ;;
        material)   THEME="Vimix-doder-dark";  CURSOR="Erika-Furudo"; MODE="dark" ;;
        panels)   THEME="Vimix-white";  CURSOR="Bibata-Modern-Ice"; MODE="dark" ;;
        shades)   THEME="Vimix-doder";  CURSOR="Erika-Furudo"; MODE="light" ;;
        shapes)   THEME="Vimix-white";  CURSOR="Bibata-Modern-Ice"; MODE="dark" ;;
        yatch) THEME="Vimix-white"; CURSOR="Kiana"; MODE="dark" ;;
        *)     THEME="Vimix-white-dark"; CURSOR="Bibata-Modern-Ice"; MODE="dark";;
    esac

    # Terapkan Matugen
    if ERROR_MSG=$(matugen image "$RANDOM_WALLPAPER" \
        --mode "$MODE" \
        --source-color-index 0 \
        --import-json-string "{ \"mode\": \"$MODE\", \"cursor\": \"$CURSOR\", \"gtktheme\": \"$THEME\" }" 2>&1); then
         
        dunstify -u normal -a "Theme Manager" "Theme Applied!" "Rice: $RICE\nWallpaper: $(basename "$RANDOM_WALLPAPER")"
    else
        dunstify -r 999 -u critical -a "Theme Manager" "Failed!" "$ERROR_MSG"
        exit 1
    fi

    # Apply GTK & Kitty
    set-gtk-theme "dynamic" "$THEME" "$CURSOR"
    kitten @ --to unix:/tmp/kitty set-colors --all "$HOME/.config/kitty/themes/racooonfig.conf" || true

    "$DIR/rices/$RICE/launch.sh" &
}

preview_theme() {
    local style="$1"
    if [[ -z "$style" || ! -d "$DIR/rices/$style" ]]; then
        usage
    fi

    pkill polybar || true
    while pgrep -f polybar >/dev/null; do sleep 0.2; done

    echo "Previewing: $style"
    "$DIR/rices/$style/preview.sh" &
}

# Logic switch
if [[ "$action" == "--preview" ]]; then
    preview_theme "$theme_name"
else
    set_theme
fi

wait
