#!/usr/bin/env bash

WIFI_STATE=$(nmcli -t -f WIFI g)
ACTIVE=$(nmcli -t -f ACTIVE,SSID,SIGNAL dev wifi | grep '^yes')

SSID=$(echo "$ACTIVE" | cut -d: -f2)
STRENGTH=$(echo "$ACTIVE" | cut -d: -f3)

toggle() {
    if [[ "$WIFI_STATE" == "enabled" ]]; then
        nmcli radio wifi off
        dunstify --icon=window-close --urgency=normal \
            "Wi-Fi" "Wi-Fi has been turned off!"
    else
        nmcli radio wifi on
        dunstify --icon=checkmark --urgency=normal \
            "Wi-Fi" "Wi-Fi has been turned on, you are back online!"
    fi
}

icon() {
    if [[ -z "$STRENGTH" ]]; then
        echo "󰤭"
    elif [[ "$STRENGTH" -ge 80 ]]; then
        echo "󰤨"
    elif [[ "$STRENGTH" -ge 60 ]]; then
        echo "󰤥"
    elif [[ "$STRENGTH" -ge 40 ]]; then
        echo "󰤢"
    elif [[ "$STRENGTH" -ge 20 ]]; then
        echo "󰤟"
    else
        echo "󰤯"
    fi
}

status() {
    if [[ "$WIFI_STATE" == "enabled" && -n "$SSID" ]]; then
        echo "$SSID"
    else
        echo "Disconnected"
    fi
}

class() {
    if [[ "$WIFI_STATE" == "enabled" && -n "$SSID" ]]; then
        echo "󰤨"
    else
        echo "󰤭"
    fi
}

case "$1" in
    --toggle)
        toggle
        ;;
    --icon)
        icon
        ;;
    --status)
        status
        ;;
    --class)
        class
        ;;
esac
