#!/usr/bin/env bash

icon() {
    if [[ "$(pamixer --get-mute)" == "false" ]]; then
        vol=$(pamixer --get-volume)

        if [[ ${vol} -ge 80 ]]; then
            echo "¾░ò¥"
        elif [[ ${vol} -ge 40 ]]; then
            echo "¾░ûÇ"
        elif [[ ${vol} -ge 10 ]]; then
            echo "¾░ò┐"
        else
            echo "¾░Øƒ"
        fi
    else
        echo "¾░Øƒ"
    fi
}

getvol() {
    pamixer --get-volume
}

if [[ $1 == "--icon" ]]; then
    icon
elif [[ $1 == "--value" ]]; then
    getvol
fi
