directory: /srv/share/music
library: ~/.config/beets/library.db
art_filename: albumart

import:
  move: yes              # Memindahkan file dari folder unduhan ke folder koleksi rapi 
  write: yes             # menulis metadata langsung ke dalam file audio 
  autotag: yes           # WAJIB aktif untuk mencari metadata resmi
  resume: no             # update ke 'no' agar skrip otomatis tidak macet untuk meminta konfirmasi resume
  incremental: yes       # mengabaikan file yang sudah pernah diimport sebelumnya
  quiet_fallback: asis   # PENTINH: jika tidak ada di internet, gunakan nama dari youtube (jangan di skip)

paths:
  default: '%first{$genres}/$albumartist/$album/$track $title'
  singleton: 'Singletons/$artist - $title'
  comp: '%first{$genres}/$album/$track $title'
  albumtype:soundtrack: 'Soundtracks/$album/$track $title'

pluginpath: ~/beets/myplugins
plugins:
  - musicbrainz   # WAJIB ditambahkan agar plugin chroma bisa menarik data metadata resmi
  - fetchart
  - lyrics
  - replaygain
  - chroma
  - scrub
  - duplicates
  - bpd

disabled_plugins: []

fetchart:
    auto: yes
    minwidth: 0
    maxwidth: 0
    quality: 0
    max_filesize: 0
    enforce_ratio: no
    cautious: true
    cover_names:
      - cover
      - front
      - art
      - album
      - folder
    fallback:
    sources:
      - filesystem
      - coverart
      - itunes
      - amazon
      - albumart
      - cover_art_url
    store_source: no
    high_resolution: no
    deinterlace: no
    cover_format:
    google_key: REDACTED
    google_engine: REDACTED
    lastfm_key: REDACTED
    fanarttv_key: REDACTED

lyrics:
  auto: yes
  synced: yes
  keep_synced: yes
  force: yes
  local: no
  print: no
  sources:
    - lrclib     # Diperbaiki format list-nya menggunakan tanda strip baku

replaygain:
    overwrite: yes
    auto: yes
    backend: ffmpeg
    threads: 4
    parallel_on_import: no
    per_disc: no
    peak: 'true'
    targetlevel: 89
    r128: [Opus]
    r128_targetlevel: 84
    command: ''
    noclip: yes

chroma:
    search_limit: 5
    data_source_mismatch_penalty: 0.5
    auto: yes

scrub:
    auto: yes

duplicates:
    album: no
    checksum: 'ffmpeg'
    copy: ''
    count: no
    delete: no
    format: ''
    full: no
    keys: []
    merge: no
    move: ''
    path: no
    tiebreak: {}
    strict: no
    tag: ''
    remove: no

ui:
    color: yes
