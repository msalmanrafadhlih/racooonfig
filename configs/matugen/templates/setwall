#!/usr/bin/env bash
# this script Generated by Matugen
# if you want to edit this! the actual file path at:
# ~/.config/matugen/templates/setwall

# Mengambil argumen pertama, jika kosong default ke --apply
action="${1:-"--apply"}"

DIR="$HOME/.config/$XDG_CURRENT_DESKTOP"
read -r RICE < "$DIR/.rice"

MODE={{ mode }}

if [[ "$MODE" == "light" ]]; then
    mode="-l"
    scheme="lighten"
    alpa=70
    fg_args=(--fg "#1a1a1a") 
else
    mode=""
    scheme="darken"
    alpa=70
    fg_args=() 
fi

setwall() {
    img=$1

    if [[ $XDG_SESSION_TYPE == "x11" ]]; then
        feh --bg-fill "$img" &
    else
        awww img "$img" &
    fi
}

usage() {
    local wall_default={{ image }}
    
    setwall "$wall_default" &

    wal -i "$wall_default" \
        $mode \
        --cols16 "$scheme" \
        -q "${fg_args[@]}" \
        --vte \
        -n -e \
        -a "$alpa" \
        --contrast 4.5 \
        --backend haishoku &
}

manual() {
    local image="$1"
    local pywal="$DIR/rices/$RICE/scripts/pywal.sh"
    
    # Validasi: Jika argumen kosong ATAU file tidak ada
    if [[ -z "$image" || ! -f "$image" ]]; then
       local file
       file=$(basename "$image" 2>/dev/null || echo "File")
       echo "Error: '$file' no such file in directory."
       return 1 
    fi

    if [[ ! -f "$pywal" ]]; then
        setwall "$image" &
    
        wal -i "$image" \
            $mode \
            --cols16 "$scheme" \
            -q "${fg_args[@]}" \
            --vte \
            -n -e \
            -a "$alpa" \
            --contrast 4.5 \
            --backend haishoku &
    else
        $pywal "$image" &
    fi
}

# Logic switch
if [[ "$action" == "--apply" ]]; then
    usage
else
    manual "$action"
fi

sleep 0.5

if command -v WallSync &> /dev/null; then
    WallSync &
fi

wait
